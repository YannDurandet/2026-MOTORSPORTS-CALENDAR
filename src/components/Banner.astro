---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<div class="banner-container">
  <picture>
    <source media="(min-width: 768px)" srcset={`${base}/assets/lauda_and_mouton--large.webp`}>
    <img src={`${base}/assets/lauda_and_mouton--mobile.webp`} alt="2026 Motorsport Calendar Banner" class="hero-banner" width="1600" height="400" fetchpriority="high">
  </picture>
</div>
