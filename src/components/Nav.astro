---
interface Props {
  activePage: 'calendar' | 'series' | 'tracks';
}
const { activePage } = Astro.props;
---
<nav class="site-nav">
  <a href={`${import.meta.env.BASE_URL}/`} class:list={["site-nav-link", { active: activePage === 'calendar' }]}>Calendar</a>
  <a href={`${import.meta.env.BASE_URL}/series`} class:list={["site-nav-link", { active: activePage === 'series' }]}>Series</a>
  <a href={`${import.meta.env.BASE_URL}/tracks`} class:list={["site-nav-link", { active: activePage === 'tracks' }]}>Tracks</a>
  <button class="search-trigger" id="search-trigger" aria-label="Search (/)">
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" width="14" height="14" aria-hidden="true">
      <circle cx="8.5" cy="8.5" r="5.5"/>
      <line x1="13" y1="13" x2="17" y2="17"/>
    </svg>
  </button>
</nav>

<style>
  .search-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--border);
    color: #556;
    cursor: pointer;
    padding: 4px 7px;
    margin-left: 6px;
    transition: color 0.15s, border-color 0.15s;
  }
  .search-trigger:hover {
    color: #aaa;
    border-color: #556;
  }
</style>
