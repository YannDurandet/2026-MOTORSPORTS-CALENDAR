---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---
<footer>
  <div class="footer--container">

    <div class="footer--inner">

      <!-- Brand -->
      <div class="footer--brand">
        <h2 class="footer--name">dord.racing</h2>
        <p class="footer--tagline">An independent 2026 motorsport master calendar tracking 25 championships across open-wheel, endurance, touring, GT, bike, and rally series.</p>
        <div class="footer--social-group">
          <div class="footer--social-label">Follow DORD</div>
          <div class="footer--socials">
            <a href="https://x.com/dord_racing"              class="footer--link" target="_blank" rel="noopener">X @dord_racing</a>
            <a href="https://www.instagram.com/dord.racing/"  class="footer--link" target="_blank" rel="noopener">Instagram @dord.racing</a>
          </div>
        </div>
        <div class="footer--social-group">
          <div class="footer--social-label">Built by Yann Durandet</div>
          <div class="footer--socials">
            <a href="https://x.com/YannDurandet"  class="footer--link" target="_blank" rel="noopener">X @YannDurandet</a>
            <a href="https://github.com/YannDurandet" class="footer--link" target="_blank" rel="noopener">GitHub</a>
            <a href="https://durandet.studio"        class="footer--link" target="_blank" rel="noopener">Brand &amp; Web Studio</a>
          </div>
        </div>
      </div>

      <!-- Site nav -->
      <div class="footer--col">
        <div class="footer--col-label">Navigate</div>
        <a href={`${base}/`}          class="footer--nav-link">Calendar</a>
        <a href={`${base}/series`}    class="footer--nav-link">Series</a>
        <a href={`${base}/tracks`}    class="footer--nav-link">Track Browser</a>
        <a href={`${base}/results`}   class="footer--nav-link">Results</a>
      </div>

      <!-- Legal -->
      <div class="footer--col">
        <div class="footer--col-label">Legal</div>
        <a href={`${base}/legal/tos`}     class="footer--nav-link">Terms of Use</a>
        <a href={`${base}/legal/privacy`} class="footer--nav-link">Privacy Policy</a>
        <a href="mailto:durandet.yann.pro@gmail.com" class="footer--nav-link" target="_blank" rel="noopener">Contact</a>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer--bottom">
      <span>© {year} Yann Durandet — Independent fan project, not affiliated with any series or sanctioning body.</span>
      <span class="footer--attribution">Race data sourced from FIA, Formula 1, Formula E, WEC, IMSA, IndyCar, MotoGP &amp; series official sources. Some links are affiliate links — we may earn a commission at no cost to you.</span>
    </div>

  </div>
</footer>
