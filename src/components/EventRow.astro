---
interface SubRace {
  badge: string;
  label: string;
  detail: string;
}

interface Race {
  label: string;
  time: string;
}

interface Props {
  series: string;
  tag: string;
  title: string;
  time: string;
  track: string;
  sprint?: boolean;
  sub?: SubRace[];
  races?: Race[];
  trackHref?: string | null;
}

const { series, tag, title, time, track, sprint, sub, races, trackHref } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const seriesHref = `${base}/series/${series}`;
const hasSub = sub && sub.length > 0;
const hasRaces = races && races.length > 0;
const sprintBadge = sprint ? ' <span class="sprint-badge">SPRINT</span>' : '';
---
<div class="event" class:list={[`ev-${series}`]} data-series={series} data-track-href={trackHref ?? undefined}>
  <div class="ev-details">
    {hasSub ? (
      <>
        <div class="toggle-row">
          <div>
            <a href={seriesHref} class={`tag t-${series}`}><Fragment set:html={tag + sprintBadge} /></a>
            <span class="title">{title}</span>
            <span class="meta-time">
              <Fragment set:html={time} />
            </span>
          </div>
          <button class="arrow-btn" aria-label="Toggle support races" aria-expanded="false">&#9660;</button>
        </div>
        <div class="sub-sched">
          {sub.map(s => (
            <div class="sub-row">
              <span class={`badge b-${s.badge}`}>{s.label}</span>
              <span class="sub-det">{s.detail}</span>
            </div>
          ))}
        </div>
      </>
    ) : hasRaces ? (
      <>
        <span class={`tag t-${series}`}><Fragment set:html={tag + sprintBadge} /></span>
        <span class="title">{title}</span>
        <div class="races-wrap">
          {races.map(r => (
            <span class="race-slot">
              <span class="race-label">{r.label}</span>
              <span class="meta-time"><Fragment set:html={r.time} /></span>
            </span>
          ))}
        </div>
      </>
    ) : (
      <>
        <span class={`tag t-${series}`}><Fragment set:html={tag + sprintBadge} /></span>
        <span class="title">{title}</span>
        <span class="meta-time">
          <Fragment set:html={time} />
        </span>
      </>
    )}
  </div>
  <div class="track-map">
    {trackHref ? (
      <a href={trackHref} tabindex="-1" aria-hidden="true">
        <img
          src={`${base}/assets/track-maps/${track}`}
          alt={`2026 ${tag} ${title} track map layout`}
          loading="lazy"
          width="60"
          height="60"
        />
      </a>
    ) : (
      <img
        src={`${base}/assets/track-maps/${track}`}
        alt={`2026 ${tag} ${title} track map layout`}
        loading="lazy"
        width="60"
        height="60"
      />
    )}
  </div>
</div>
