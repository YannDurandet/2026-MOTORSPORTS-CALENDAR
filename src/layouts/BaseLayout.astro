---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const { title, description, ogImage, canonicalUrl } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const defaultOgImage = `https://dord.racing/assets/lauda_and_mouton--large.webp`;
const resolvedOgImage = ogImage || defaultOgImage;
const resolvedCanonical = canonicalUrl || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#0b0f12">
  <meta name="description" content={description}>
  <link rel="canonical" href={resolvedCanonical} />
  <link rel="icon" href={`${base}/assets/website-icon.svg`} type="image/svg+xml">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="2026 Motorsport Master Calendar">
  <meta property="og:url" content={resolvedCanonical}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={resolvedOgImage}>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={resolvedOgImage}>
  <title>{title}</title>
  <meta name="astro-base" content={base}>
  <style>
    @font-face {
      font-family: 'Orbitron';
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url('/assets/fonts/orbitron-400.woff2') format('woff2');
      unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
    @font-face {
      font-family: 'Orbitron';
      font-style: normal;
      font-weight: 900;
      font-display: swap;
      src: url('/assets/fonts/orbitron-900.woff2') format('woff2');
      unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
    @font-face {
      font-family: 'Roboto Mono';
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url('/assets/fonts/roboto-mono-400.woff2') format('woff2');
      unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
    @font-face {
      font-family: 'Roboto Mono';
      font-style: normal;
      font-weight: 700;
      font-display: swap;
      src: url('/assets/fonts/roboto-mono-700.woff2') format('woff2');
      unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
    @font-face {
      font-family: 'Inter';
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url('/assets/fonts/inter-400.woff2') format('woff2');
      unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
    @font-face {
      font-family: 'Inter';
      font-style: normal;
      font-weight: 800;
      font-display: swap;
      src: url('/assets/fonts/inter-800.woff2') format('woff2');
      unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
  </style>
  <slot name="head" />
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <div class="container">
    <slot />
  </div>

  <!-- Sticky bottom nav — appears when header nav scrolls off screen -->
  <div id="sticky-nav-bar" class="sticky-nav-bar" aria-hidden="true">
    <nav class="sticky-nav-inner">
      <a href={`${base}/`}       class="sticky-nav-link" data-page="calendar" aria-label="Calendar">
        <img src={`${base}/assets/calendar-icon.svg`} alt="" width="22" height="22">
        <span class="sticky-nav-label">Calendar</span>
      </a>
      <a href={`${base}/series`} class="sticky-nav-link" data-page="series" aria-label="Series">
        <img src={`${base}/assets/series-icon.svg`} alt="" width="22" height="22">
        <span class="sticky-nav-label">Series</span>
      </a>
      <a href={`${base}/tracks`} class="sticky-nav-link" data-page="tracks" aria-label="Tracks">
        <img src={`${base}/assets/tracks-icon.svg`} alt="" width="22" height="22">
        <span class="sticky-nav-label">Tracks</span>
      </a>
      <a href={`${base}/results`} class="sticky-nav-link" data-page="results" aria-label="Results">
        <img src={`${base}/assets/results-icon.svg`} alt="" width="22" height="22">
        <span class="sticky-nav-label">Results</span>
      </a>
      <button class="sticky-nav-link" id="sticky-search-trigger" aria-label="Search">
        <img src={`${base}/assets/search-icon.svg`} alt="" width="22" height="22">
        <span class="sticky-nav-label">Search</span>
      </button>
    </nav>
  </div>

  <!-- Search modal -->
  <div id="search-overlay" class="search-overlay" hidden role="dialog" aria-modal="true" aria-label="Search">
    <div class="search-backdrop" id="search-backdrop"></div>
    <div class="search-modal">
      <div class="search-input-row">
        <label for="search-input" class="sr-only">Search tracks and series</label>
        <svg class="search-modal-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16" aria-hidden="true">
          <circle cx="8.5" cy="8.5" r="5.5"/>
          <line x1="13" y1="13" x2="17" y2="17"/>
        </svg>
        <input id="search-input" class="search-input" type="search" placeholder="Search tracks & series…" autocomplete="off" spellcheck="false" />
        <kbd class="search-kbd" aria-label="Press Escape to close">ESC</kbd>
      </div>
      <div id="search-results" class="search-results"></div>
    </div>
  </div>

  <!-- Back to top -->
  <button id="back-to-top" class="back-to-top" aria-label="Back to top" hidden>↑ TOP</button>

  <!-- Email obfuscation — assembles mailto links client-side so the address
       never appears in raw HTML. Any <a class="js-mailto" data-u="user" data-d="domain">
       gets its href set to mailto:user@domain. Add data-show to also replace the text. -->
  <script>
    document.querySelectorAll<HTMLAnchorElement>('.js-mailto').forEach(el => {
      const email = el.dataset.u + '@' + el.dataset.d;
      el.href = 'mailto:' + email;
      if ('show' in el.dataset) el.textContent = email;
    });
  </script>

  <style is:global>
    /* ── Skip link ───────────────────────────────────────────────────────────── */
    .skip-link {
      position: absolute;
      top: -100%;
      left: 0;
      z-index: 99999;
      background: #fff;
      color: #000;
      font-family: 'Roboto Mono', monospace;
      font-size: 0.9rem;
      font-weight: 700;
      padding: 12px 20px;
      text-decoration: none;
      border-bottom-right-radius: 4px;
    }
    .skip-link:focus {
      top: 0;
    }
    /* ── Screen reader only utility ──────────────────────────────────────────── */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    /* ── Search overlay ──────────────────────────────────────────────────────── */
    .search-overlay {
      position: fixed;
      inset: 0;
      z-index: 9000;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding-top: 10vh;
    }
    .search-overlay[hidden] { display: none; }

    .search-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.75);
      backdrop-filter: blur(4px);
    }

    .search-modal {
      position: relative;
      z-index: 1;
      width: min(660px, calc(100vw - 32px));
      background: #0b0f12;
      border: 1px solid #1e2d38;
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.9);
    }

    /* ── Input row ───────────────────────────────────────────────────────────── */
    .search-input-row {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 16px 18px;
      border-bottom: 1px solid #1e2d38;
    }

    .search-modal-icon { color: #3a5060; flex-shrink: 0; }

    .search-input {
      flex: 1;
      background: none;
      border: none;
      outline: none;
      font-family: 'Roboto Mono', monospace;
      font-size: 0.9rem;
      color: #c3c6c8;
      letter-spacing: 0.02em;
    }
    .search-input::placeholder { color: #334; }
    .search-input::-webkit-search-cancel-button { display: none; }

    .search-kbd {
      font-family: 'Roboto Mono', monospace;
      font-size: 0.58rem;
      color: #334;
      border: 1px solid #1e2d38;
      padding: 3px 7px;
      letter-spacing: 0.06em;
      flex-shrink: 0;
      user-select: none;
    }

    /* ── Results list ────────────────────────────────────────────────────────── */
    .search-results {
      max-height: 58vh;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: #1e2d38 transparent;
    }

    .search-group-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 18px 6px;
    }
    .search-group-header-label {
      font-family: 'Roboto Mono', monospace;
      font-size: 0.54rem;
      color: #3a5060;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      white-space: nowrap;
    }
    .search-group-header-line {
      flex: 1;
      height: 1px;
      background: #1a2530;
    }

    .search-result-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 10px 18px;
      text-decoration: none;
      border-left: 2px solid transparent;
      transition: background 0.1s, border-color 0.1s;
    }
    .search-result-item:hover,
    .search-result-item.focused {
      background: #0f1820;
      border-left-color: #2a5070;
    }

    .search-result-body {
      display: flex;
      flex-direction: column;
      gap: 3px;
      min-width: 0;
    }

    .search-result-name {
      font-family: 'Inter', sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      color: #c3c6c8;
      letter-spacing: 0.01em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .search-result-sub {
      font-family: 'Roboto Mono', monospace;
      font-size: 0.62rem;
      color: #445;
      letter-spacing: 0.03em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .search-result-arrow {
      margin-left: auto;
      color: #2a3540;
      font-size: 0.7rem;
      flex-shrink: 0;
      transition: color 0.1s;
    }
    .search-result-item:hover .search-result-arrow,
    .search-result-item.focused .search-result-arrow {
      color: #4a7090;
    }

    .search-empty {
      padding: 28px 18px;
      font-family: 'Roboto Mono', monospace;
      font-size: 0.7rem;
      color: #334;
      text-align: center;
      letter-spacing: 0.04em;
    }

    .search-footer {
      display: flex;
      gap: 16px;
      padding: 8px 18px;
      border-top: 1px solid #1a2530;
    }
    .search-hint {
      display: flex;
      align-items: center;
      gap: 5px;
      font-family: 'Roboto Mono', monospace;
      font-size: 0.56rem;
      color: #2a3540;
      letter-spacing: 0.06em;
    }
    .search-hint kbd {
      border: 1px solid #1e2d38;
      padding: 1px 5px;
      font-family: inherit;
      font-size: inherit;
    }

    /* ── Cookie consent banner ───────────────────────────────────────────────── */
    /* Floats above the sticky nav (z-index 250 > nav's 200). Same island style. */
    .cookie-banner {
      position: fixed;
      bottom: 32px;
      left: 32px;
      z-index: 250;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      padding: 14px 18px;
      width: max-content;
      max-width: min(480px, calc(100vw - 32px));
      background: rgba(8, 15, 22, 0.97);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 4px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6), 0 2px 8px rgba(0, 0, 0, 0.4);
    }
    .cookie-banner[hidden] { display: none; }

    .cookie-banner-text {
      font-family: 'Roboto Mono', monospace;
      font-size: 0.66rem;
      color: #8a9aaa;
      letter-spacing: 0.02em;
      line-height: 1.6;
      margin: 0;
    }

    .cookie-banner-actions {
      display: flex;
      gap: 8px;
      align-self: flex-end;
    }

    .cookie-btn {
      font-family: 'Roboto Mono', monospace;
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 6px 14px;
      border: 1px solid;
      cursor: pointer;
      background: none;
      transition: color 0.15s, border-color 0.15s, background 0.15s;
    }

    .cookie-btn--accept {
      color: #c3c6c8;
      border-color: #2e4a5e;
    }
    .cookie-btn--accept:hover {
      color: #fff;
      border-color: #4a7090;
      background: #0d1822;
    }

    .cookie-btn--decline {
      color: #445;
      border-color: #1a2530;
    }
    .cookie-btn--decline:hover {
      color: #8a9aaa;
      border-color: #2e3f50;
    }
  </style>

  <script>
    // ── Sticky nav ──────────────────────────────────────────────────────────────
    const headerNav = document.querySelector('.site-nav');
    const stickyBar = document.getElementById('sticky-nav-bar');
    if (headerNav && stickyBar) {
      // Mark active link by URL path
      const path = window.location.pathname.replace(/\/$/, '');
      stickyBar.querySelectorAll<HTMLAnchorElement>('.sticky-nav-link').forEach(link => {
        const page = link.dataset.page;
        if (page === 'calendar' && (path === '' || path.endsWith('/racing') || !path.includes('/series') && !path.includes('/tracks'))) {
          link.classList.add('active');
        } else if (page === 'series' && path.includes('/series')) {
          link.classList.add('active');
        } else if (page === 'tracks' && path.includes('/tracks')) {
          link.classList.add('active');
        } else if (page === 'results' && path.includes('/results')) {
          link.classList.add('active');
        }
      });

      const observer = new IntersectionObserver(
        ([entry]) => {
          const show = !entry.isIntersecting;
          stickyBar.classList.toggle('visible', show);
          stickyBar.setAttribute('aria-hidden', show ? 'false' : 'true');
        },
        { threshold: 0 }
      );
      observer.observe(headerNav);
    }

    // ── Back to top ─────────────────────────────────────────────────────────────
    const btt = document.getElementById('back-to-top');
    if (btt) {
      window.addEventListener('scroll', () => { btt.hidden = window.scrollY < 500; }, { passive: true });
      btt.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    }

    // ── Global search ────────────────────────────────────────────────────────────
    const overlay   = document.getElementById('search-overlay') as HTMLElement | null;
    const backdrop  = document.getElementById('search-backdrop');
    const input     = document.getElementById('search-input') as HTMLInputElement | null;
    const results   = document.getElementById('search-results');

    let searchIndex: any[] | null = null;
    let focusIdx = -1;
    let searchTriggerEl: HTMLElement | null = null;

    function getFocusableEls(): HTMLElement[] {
      if (!overlay) return [];
      return Array.from(overlay.querySelectorAll<HTMLElement>(
        'input, button, a[href], [tabindex]:not([tabindex="-1"])'
      )).filter(el => !el.hasAttribute('disabled') && el.offsetParent !== null);
    }

    function openSearch(triggerEl?: HTMLElement) {
      if (!overlay) return;
      searchTriggerEl = triggerEl ?? (document.activeElement as HTMLElement) ?? null;
      overlay.hidden = false;
      document.body.style.overflow = 'hidden';
      setTimeout(() => input?.focus(), 30);
    }

    function closeSearch() {
      if (!overlay) return;
      overlay.hidden = true;
      document.body.style.overflow = '';
      if (input) input.value = '';
      if (results) results.innerHTML = '';
      focusIdx = -1;
      searchTriggerEl?.focus();
      searchTriggerEl = null;
    }

    async function loadIndex() {
      if (searchIndex) return;
      const base = document.querySelector<HTMLMetaElement>('meta[name="astro-base"]')?.content || '';
      const res = await fetch(`${base}/data/search.json`);
      searchIndex = await res.json();
    }

    function escapeHtml(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function renderResults(query: string) {
      if (!results || !searchIndex) return;
      const q = query.trim().toLowerCase();
      if (!q) { results.innerHTML = ''; focusIdx = -1; return; }

      const matched = searchIndex.filter(item => {
        const haystack = item.t === 'track'
          ? `${item.name} ${item.city} ${item.country}`.toLowerCase()
          : `${item.name} ${item.tagline}`.toLowerCase();
        return haystack.includes(q);
      }).slice(0, 20);

      const tracks  = matched.filter(i => i.t === 'track');
      const series  = matched.filter(i => i.t === 'series');

      const base = document.querySelector<HTMLMetaElement>('meta[name="astro-base"]')?.content || '';

      if (matched.length === 0) {
        results.innerHTML = `<div class="search-empty">No results for "${escapeHtml(query)}"</div>`;
        focusIdx = -1;
        return;
      }

      const arrow = `<span class="search-result-arrow">→</span>`;

      function groupHeader(label: string) {
        return `<div class="search-group-header">
          <span class="search-group-header-label">${label}</span>
          <span class="search-group-header-line"></span>
        </div>`;
      }

      let html = '';
      if (series.length) {
        html += groupHeader('Series');
        for (const s of series) {
          html += `<a class="search-result-item" href="${base}/series/${s.slug}">
            <div class="search-result-body">
              <span class="search-result-name">${s.name}</span>
              <span class="search-result-sub">${s.tagline}</span>
            </div>
            ${arrow}
          </a>`;
        }
      }
      if (tracks.length) {
        html += groupHeader('Circuits');
        for (const t of tracks) {
          html += `<a class="search-result-item" href="${base}/tracks/${t.slug}">
            <div class="search-result-body">
              <span class="search-result-name">${t.name}</span>
              <span class="search-result-sub">${t.city} · ${t.country}</span>
            </div>
            ${arrow}
          </a>`;
        }
      }

      html += `<div class="search-footer">
        <span class="search-hint"><kbd>↑↓</kbd> navigate</span>
        <span class="search-hint"><kbd>↵</kbd> open</span>
        <span class="search-hint"><kbd>esc</kbd> close</span>
      </div>`;

      results.innerHTML = html;
      focusIdx = -1;
    }

    function moveFocus(dir: number) {
      if (!results) return;
      const items = Array.from(results.querySelectorAll<HTMLElement>('.search-result-item'));
      if (!items.length) return;
      items[focusIdx]?.classList.remove('focused');
      focusIdx = Math.max(0, Math.min(items.length - 1, focusIdx + dir));
      items[focusIdx].classList.add('focused');
      items[focusIdx].scrollIntoView({ block: 'nearest' });
    }

    // Wire triggers
    const headerTrigger = document.getElementById('search-trigger');
    const stickyTrigger = document.getElementById('sticky-search-trigger');
    headerTrigger?.addEventListener('click', () => openSearch(headerTrigger));
    stickyTrigger?.addEventListener('click', () => openSearch(stickyTrigger));
    backdrop?.addEventListener('click', closeSearch);

    input?.addEventListener('input', async () => {
      await loadIndex();
      renderResults(input.value);
    });

    input?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowDown') { e.preventDefault(); moveFocus(1); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); moveFocus(-1); }
      else if (e.key === 'Enter') {
        const focused = results?.querySelector<HTMLAnchorElement>('.search-result-item.focused');
        if (focused) { closeSearch(); window.location.href = focused.href; }
      }
      else if (e.key === 'Escape') closeSearch();
    });

    // Focus trap: keep Tab / Shift+Tab cycling inside the modal
    overlay?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key !== 'Tab') return;
      if (overlay.hidden) return;
      const focusable = getFocusableEls();
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    });

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (overlay?.hidden === false) return; // already open
      if (e.key === '/' && !['INPUT','TEXTAREA','SELECT'].includes((e.target as Element)?.tagName)) {
        e.preventDefault();
        openSearch(document.activeElement as HTMLElement);
      }
    });
  </script>

  <!-- Cookie consent banner -->
  <div id="cookie-banner" class="cookie-banner" hidden>
    <p class="cookie-banner-text">We use analytics cookies to understand how visitors find us. No advertising, no third parties.</p>
    <div class="cookie-banner-actions">
      <button id="cookie-accept" class="cookie-btn cookie-btn--accept">Accept</button>
      <button id="cookie-decline" class="cookie-btn cookie-btn--decline">Decline</button>
    </div>
  </div>

  <script is:inline>
    (function () {
      // ── GA4 Measurement ID ─────────────────────────────────────────────────────
      var GA4_ID = 'G-9SV3R1JJET';

      function getCookie(name) {
        var match = document.cookie.match(new RegExp('(?:^|; )' + name.replace(/([.*+?^=!:${}()|[\]/\\])/g, '\\$1') + '=([^;]*)'));
        return match ? decodeURIComponent(match[1]) : null;
      }

      function setCookie(name, value, days) {
        var expires = new Date(Date.now() + days * 864e5).toUTCString();
        document.cookie = name + '=' + encodeURIComponent(value) + '; expires=' + expires + '; path=/; SameSite=Lax; Secure';
      }

      function loadGA4() {
        if (window.__ga4Loaded) return;
        window.__ga4Loaded = true;
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA4_ID;
        s.async = true;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag() { window.dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', GA4_ID);
      }

      function hideBanner() {
        var banner = document.getElementById('cookie-banner');
        if (banner) banner.hidden = true;
      }

      function showBanner() {
        var banner = document.getElementById('cookie-banner');
        if (banner) banner.hidden = false;
      }

      // Check existing consent on every page load
      var consent = getCookie('cookie_consent');
      if (consent === 'granted') {
        loadGA4();
        // banner stays hidden (default)
      } else if (consent === 'denied') {
        // banner stays hidden, GA4 never loads
      } else {
        // No consent recorded — show the banner
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', showBanner);
        } else {
          showBanner();
        }
      }

      // Wire buttons (safe to run immediately — banner is already in DOM)
      document.addEventListener('DOMContentLoaded', function () {
        var acceptBtn = document.getElementById('cookie-accept');
        var declineBtn = document.getElementById('cookie-decline');
        if (acceptBtn) {
          acceptBtn.addEventListener('click', function () {
            setCookie('cookie_consent', 'granted', 365);
            loadGA4();
            hideBanner();
          });
        }
        if (declineBtn) {
          declineBtn.addEventListener('click', function () {
            setCookie('cookie_consent', 'denied', 365);
            hideBanner();
          });
        }
      });
    })();
  </script>
</body>
</html>
