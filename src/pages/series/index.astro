---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Banner from '../../components/Banner.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

import seriesContent from '../../../data/seriesContent.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const categoryOrder = ['Open Wheel', 'Bike', 'Endurance', 'GT / Sports Car', 'Rally', 'Touring'];

const grouped = categoryOrder.map(cat => ({
  category: cat,
  series: (seriesContent as any[]).filter((s: any) => s.category === cat),
})).filter(g => g.series.length > 0);

const seriesImages: Record<string, string> = {
  'f1':       'f1-series-bg.webp',
  'f1a':      'f1a-series-bg.webp',
  'fe':       'fe-series-bg.webp',
  'sf':       'sf-series-bg.webp',
  'wec':      'wec-series-bg.webp',
  'imsa':     'imsa-series-bg.webp',
  'wrc':      'wrc-series-bg.webp',
  'erc':      'erc-series-bg.webp',
  'indycar':  'indycar-series-bg.webp',
  'nascar':   'nascar-series-bg.webp',
  'motogp':   'motogp-series-bg.webp',
  'wsbk':     'wsbk-series-bg.webp',
  'dtm':      'dtm-series-bg.webp',
  'btcc':     'btcc-series-bg.webp',
  'supercars':'scc-series-bg.webp',
  'elms':     'elms-series-bg.webp',
  'gtwce':    'gtwce-series-bg.webp',
  'gtwca':    'gtwca-series-bg.webp',
  'nls':      'nls-series-bg.webp',
  'igtc':     'igtc-series-bg.webp',
  'tcr':      'tcr-series-bg.webp',
  'h24eu':    '24h-series-bg.webp',
  'psc':      'psc-series-bg.webp',
  'bgt':      'bgtc-series-bg.webp',
  'eurx':     'erx-series-bg.webp',
};
---
<BaseLayout
  title="2026 Motorsport Series Guide — F1, MotoGP, WEC, IndyCar & More"
  description="Complete guide to every 2026 motorsport championship — schedules, teams, and history for F1, WEC, MotoGP, IndyCar, NASCAR and 20 more series."
  canonicalUrl="https://dord.racing/series"
  ogImage="https://dord.racing/assets/og/og-series.webp"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dord.racing" },
        { "@type": "ListItem", "position": 2, "name": "Racing Series", "item": "https://dord.racing/series" }
      ]
    })} />
  </Fragment>
  <Banner />
  <header>
    <div class="header--left">
      <div class="header--dept">The Department of Racing Drivers</div>
      <h1>2026 Racing<br>Series Guide</h1>
      <p class="header--page-desc">Every championship on the 2026 calendar, from the pinnacle of open-wheel racing to the legendary Nordschleife.</p>
      <div class="meta">SYSTEM TIMEZONE: PARIS (CET/CEST)</div>
      <Nav activePage="series" />
    </div>
  </header>

  <div class="main-section">
    {grouped.map(group => (
      <>
        <div class="series-index-category">{group.category}</div>
        <div class="series-index-grid">
          {group.series.map((s: any) => (
            <a href={`${base}/series/${s.slug}`} class={`series-index-card series-index-card--${s.slug}`}>
              <div class="series-index-img-wrap">
                {seriesImages[s.slug]
                  ? <img src={`${base}/assets/series-grid-images/${seriesImages[s.slug]}`} alt={`${s.name} 2026 race schedule`} loading="lazy" />
                  : <div class="series-index-img-placeholder">{s.name}</div>
                }
                <div class="sc-countdown" data-series={s.slug}>
                  <div class="sc-race">LOADING…</div>
                  <div class="sc-time" id={`sc-${s.slug}`} style={`color: var(--${s.slug}-c, var(--${s.slug}))`}>--:--:--</div>
                </div>
              </div>
              <div class="series-index-accent" style={`background: var(--${s.slug})`}></div>
              <div class="series-index-body">
                <div class="series-index-name">{s.name}</div>
                <div class="series-index-region">{s.region}</div>
                <div class="series-index-tagline">{s.tagline}</div>
                <div class="series-index-cta">View Series →</div>
              </div>
            </a>
          ))}
        </div>
      </>
    ))}

    <Footer />
  </div>
</BaseLayout>

<script>
  (async () => {
    const base = (document.querySelector('meta[name="astro-base"]') as HTMLMetaElement)?.content ?? '';

    // Update timezone notice
    const tzEl = document.querySelector<HTMLElement>('.meta');
    const userTz = Intl.DateTimeFormat().resolvedOptions().timeZone;
    if (tzEl && userTz !== 'Europe/Paris') {
      tzEl.textContent = `ALL TIMES IN YOUR TIMEZONE: ${userTz.replace(/_/g, ' ').toUpperCase()}`;
    }

    let data: Record<string, Array<{ name: string; date: string; _ts?: number }>> = {};
    try {
      const res = await fetch(`${base}/data/series.json`);
      data = await res.json();
    } catch { return; }

    // Pre-cache timestamps
    for (const list of Object.values(data)) {
      for (const race of list) race._ts = new Date(race.date).getTime();
    }

    // Cache DOM refs
    const timeEls: Record<string, HTMLElement | null> = {};
    const raceEls: Record<string, HTMLElement | null> = {};
    for (const key of Object.keys(data)) {
      timeEls[key] = document.getElementById(`sc-${key}`);
      raceEls[key] = document.querySelector<HTMLElement>(`.sc-countdown[data-series="${key}"] .sc-race`);
    }

    function pad(n: number) { return String(n).padStart(2, '0'); }

    function tick() {
      const now = Date.now();
      for (const [key, list] of Object.entries(data)) {
        const tEl = timeEls[key];
        const rEl = raceEls[key];
        if (!tEl || !rEl) continue;

        const next = list.find(r => (r._ts ?? 0) > now);

        if (!next) {
          rEl.textContent = 'SEASON COMPLETE';
          tEl.textContent = 'OFF SEASON';
          tEl.classList.add('sc-off');
          continue;
        }

        tEl.classList.remove('sc-off');
        rEl.textContent = next.name;

        const diff = (next._ts ?? 0) - now;
        const d = Math.floor(diff / 864e5);
        const h = Math.floor((diff % 864e5) / 36e5);
        const m = Math.floor((diff % 36e5) / 6e4);
        const s = Math.floor((diff % 6e4) / 1e3);

        tEl.textContent = d > 0
          ? `${d}d ${pad(h)}h ${pad(m)}m ${pad(s)}s`
          : `${pad(h)}h ${pad(m)}m ${pad(s)}s`;
      }
    }

    tick();
    setInterval(tick, 1000);
  })();
</script>
