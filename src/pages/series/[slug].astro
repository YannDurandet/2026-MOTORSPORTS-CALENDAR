---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Banner from '../../components/Banner.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

import seriesContent from '../../../data/seriesContent.json';
import calendarData from '../../../data/calendar.json';
import seriesRaces from '../../../data/series.json';
import tracksData from '../../../data/tracks.json';

export function getStaticPaths() {
  return (seriesContent as any[]).map((s: any) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const series = (seriesContent as any[]).find((s: any) => s.slug === slug)!;

// Filter calendar events for this series
const filteredMonths = (calendarData as any[])
  .map((month: any) => ({
    ...month,
    weeks: month.weeks
      .map((week: any) => ({
        ...week,
        events: week.events.filter((ev: any) => ev.series === slug),
      }))
      .filter((week: any) => week.events.length > 0),
  }))
  .filter((month: any) => month.weeks.length > 0);

// OG image mapping
const seriesImages: Record<string, string> = {
  'f1':'f1-series-bg.webp','f1a':'f1a-series-bg.webp','fe':'fe-series-bg.webp',
  'sf':'sf-series-bg.webp','wec':'wec-series-bg.webp','imsa':'imsa-series-bg.webp',
  'wrc':'wrc-series-bg.webp','erc':'erc-series-bg.webp','indycar':'indycar-series-bg.webp',
  'nascar':'nascar-series-bg.webp','motogp':'motogp-series-bg.webp','wsbk':'wsbk-series-bg.webp',
  'dtm':'dtm-series-bg.webp','btcc':'btcc-series-bg.webp','supercars':'scc-series-bg.webp',
  'elms':'elms-series-bg.webp','gtwce':'gtwce-series-bg.webp','gtwca':'gtwca-series-bg.webp',
  'nls':'nls-series-bg.webp','igtc':'igtc-series-bg.webp','tcr':'tcr-series-bg.webp',
  'h24eu':'24h-series-bg.webp','psc':'psc-series-bg.webp','bgt':'bgtc-series-bg.webp','eurx':'erx-series-bg.webp',
};
const ogImage = seriesImages[slug]
  ? `https://dord.racing/assets/series-grid-images/${seriesImages[slug]}`
  : undefined;

// JSON-LD data
const races = (seriesRaces as any)[slug] ?? [];

// Build SVG filename → venue lookup (more reliable than slug-stripping)
const svgToVenue = new Map<string, any>();
for (const track of tracksData as any[]) {
  for (const svg of (track.calendarSvgs ?? [])) svgToVenue.set(svg, track);
  for (const layout of (track.layouts ?? []))
    for (const svg of (layout.calendarSvgs ?? [])) svgToVenue.set(svg, track);
}

// Flatten calendar events for this series (preserves order for index matching)
const calEvents: Array<{ title: string; track: string; resultDate: string | null }> = [];
for (const month of filteredMonths) {
  for (const week of month.weeks) {
    for (const ev of week.events) {
      calEvents.push({
        title: ev.title,
        track: ev.track ?? '',
        resultDate: ev.results?.[0]?.date ?? null,
      });
    }
  }
}

const sportsOrgSchema = {
  "@context": "https://schema.org",
  "@type": "SportsOrganization",
  "name": series.name,
  "sport": "Motorsport",
  "description": series.description,
  ...(series.socials?.web ? { "url": series.socials.web } : {}),
  "sameAs": [
    series.socials?.web,
    series.socials?.x,
    series.socials?.ig,
    series.socials?.yt,
  ].filter(Boolean),
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dord.racing" },
    { "@type": "ListItem", "position": 2, "name": "Racing Series", "item": "https://dord.racing/series" },
    { "@type": "ListItem", "position": 3, "name": series.name, "item": `https://dord.racing/series/${slug}` },
  ],
};

// Fallback location data for WRC/ERC flag SVGs (no track entry in tracks.json)
const wrcLocations: Record<string, { name: string; city: string; country: string }> = {
  'monte-carlo-wrc.svg': { name: 'Rallye Monte-Carlo',       city: 'Monaco',                    country: 'MC' },
  'sweden-wrc.svg':      { name: 'Rally Sweden',             city: 'Umeå',                      country: 'SE' },
  'kenya-wrc.svg':       { name: 'Safari Rally Kenya',       city: 'Naivasha',                  country: 'KE' },
  'croatia-wrc.svg':     { name: 'Croatia Rally',            city: 'Zagreb',                    country: 'HR' },
  'spain-wrc.svg':       { name: 'Rally Islas Canarias',     city: 'Las Palmas de Gran Canaria', country: 'ES' },
  'portugal-wrc.svg':    { name: 'Rally de Portugal',        city: 'Matosinhos',                country: 'PT' },
  'japan-wrc.svg':       { name: 'Rally Japan',              city: 'Toyota',                    country: 'JP' },
  'greece-wrc.svg':      { name: 'Acropolis Rally Greece',   city: 'Lamia',                     country: 'GR' },
  'estonia-wrc.svg':     { name: 'Rally Estonia',            city: 'Tartu',                     country: 'EE' },
  'finland-wrc.svg':     { name: 'Rally Finland',            city: 'Jyväskylä',                 country: 'FI' },
  'paraguay-wrc.svg':    { name: 'Rally del Paraguay',       city: 'Luque',                     country: 'PY' },
  'chile-wrc.svg':       { name: 'Rally Chile',              city: 'Concepción',                country: 'CL' },
  'italy-wrc.svg':       { name: 'Rally Italy Sardegna',     city: 'Alghero',                   country: 'IT' },
  'saudi-wrc.svg':       { name: 'Rally Saudi Arabia',       city: 'Riyadh',                    country: 'SA' },
  // ERC-only flags
  'czechia-wrc.svg':     { name: 'Barum Czech Rally Zlín',   city: 'Zlín',                      country: 'CZ' },
  'poland-wrc.svg':      { name: '82nd Rally Poland',         city: 'Mikołajki',                 country: 'PL' },
  'wales-wrc.svg':       { name: 'Rali Ceredigion',           city: 'Aberystwyth',               country: 'GB' },
};

// Rich SportsEvent schemas — one per round
const sportsEventSchemas = calEvents.map((ev, i) => {
  const seriesDate = races[i]?.date ?? null;
  const startDate  = ev.resultDate ?? seriesDate;
  if (!startDate) return null;

  const venue = svgToVenue.get(ev.track);
  const wrcFallback = wrcLocations[ev.track];
  if (!venue && !wrcFallback) return null; // skip tbc/tbd placeholders

  return {
    "@context": "https://schema.org",
    "@type": "SportsEvent",
    "name": `${ev.title} 2026`,
    "startDate": startDate,
    "endDate": startDate,
    "url": `https://dord.racing/series/${slug}`,
    "sport": "Motorsport",
    "eventStatus": "https://schema.org/EventScheduled",
    "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
    "organizer": {
      "@type": "SportsOrganization",
      "name": series.name,
      ...(series.socials?.web ? { "url": series.socials.web } : {}),
    },
    "performer": {
      "@type": "SportsOrganization",
      "name": series.name,
      ...(series.socials?.web ? { "url": series.socials.web } : {}),
    },
    "offers": {
      "@type": "Offer",
      "url": series.socials?.web ?? `https://dord.racing/series/${slug}`,
      "availability": "https://schema.org/InStock",
    },
    "image": ogImage ?? "https://dord.racing/assets/lauda_and_mouton--large.webp",
    "location": venue ? {
      "@type": "Place",
      "name": venue.name,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": venue.city,
        "addressCountry": venue.country,
      },
      ...(venue.website ? { "url": venue.website } : {}),
    } : {
      "@type": "Place",
      "name": wrcFallback!.name,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": wrcFallback!.city,
        "addressCountry": wrcFallback!.country,
      },
    },
    "description": venue
      ? `2026 ${series.name} round ${i + 1} — ${ev.title} at ${venue.name}, ${venue.city}.`
      : `2026 ${series.name} round ${i + 1} — ${ev.title} in ${wrcFallback!.city}.`,
  };
}).filter(Boolean);

const customTitles: Record<string, string> = {
  'wec': 'WEC 2026 Schedule & Calendar — Le Mans, Spa, Fuji & More',
};
const customDescriptions: Record<string, string> = {
  'f1':      'Full 2026 Formula 1 calendar with race dates, circuits, and results. 22 Grands Prix across five continents — Australian GP to Abu Dhabi.',
  'motogp':  'Complete 2026 MotoGP calendar — 22 rounds from Thailand to Valencia. Race dates, circuits, and results for the premier motorcycle racing class.',
  'wec':     'Full 2026 FIA World Endurance Championship calendar including the 24 Hours of Le Mans. Hypercar race dates, circuits, and results.',
  'indycar': '2026 NTT IndyCar Series schedule — 16 rounds from St. Petersburg to Laguna Seca, including the Indianapolis 500. Race dates, circuits, and results.',
  'nascar':  '2026 NASCAR Cup Series schedule — 36 races across ovals, short tracks, and road courses. Race dates, results, and circuits from the Daytona 500 to Phoenix.',
  'wsbk':    '2026 WorldSBK calendar — 12 rounds, three races per weekend. Race dates, circuit guide, and results for the Superbike World Championship.',
  'btcc':    '2026 British Touring Car Championship schedule — 10 rounds, 30 races across the UK\'s best circuits. Race dates, results, and championship standings.',
  'wrc':     '2026 FIA World Rally Championship schedule — 13 rallies across five continents. Race dates, stages, and results from Monte Carlo to Japan.',
};
const pageTitle       = customTitles[slug]       ?? `${series.name} 2026 Schedule, Calendar & Results — dord.racing`;
const pageDescription = customDescriptions[slug] ?? series.tagline;
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={`https://dord.racing/series/${slug}`}
  ogImage={ogImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(sportsOrgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {sportsEventSchemas.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(sportsEventSchemas)} />
    )}
  </Fragment>
  <Banner />
  <header>
    <div class="header--left">
      <div class="header--dept">The Department of Racing Drivers</div>
      <h1>2026 Racing Series</h1>
      <div class="meta">SYSTEM TIMEZONE: PARIS (CET/CEST)</div>
      <Nav activePage="series" />
    </div>
  </header>

  <main id="main-content" class="main-section">
    <a href={`${base}/`} class="back-link">← Full Master Calendar</a>

    <div class={`series-hero series-hero--${slug}`}>
      <div class="series-hero-accent" style={`background: var(--${slug})`}></div>
      <div class="series-hero-content">
        <div class="series-badges">
          <span class="series-badge">{series.category}</span>
          <span class="series-badge">{series.region}</span>
        </div>
        <h2 class="series-hero-name">{series.name}</h2>
        <p class="series-description">{series.description}</p>
        {series.socials && (
          <div class="series-socials">
            {series.socials.web && (
              <a href={series.socials.web} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Official website">
                <img src={`${base}/assets/website-icon.svg`} alt="" width="18" height="18" />
              </a>
            )}
            {series.socials.ig && (
              <a href={series.socials.ig} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Instagram">
                <img src={`${base}/assets/ig-icon.svg`} alt="" width="18" height="18" />
              </a>
            )}
            {series.socials.x && (
              <a href={series.socials.x} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="X">
                <img src={`${base}/assets/x-icon.svg`} alt="" width="18" height="18" />
              </a>
            )}
            {series.socials.yt && (
              <a href={series.socials.yt} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="YouTube">
                <img src={`${base}/assets/yt-icon.svg`} alt="" width="18" height="18" />
              </a>
            )}
          </div>
        )}
      </div>
    </div>

    <section class="series-section">
      <h3 class="series-section-title">History</h3>
      <p class="series-history">{series.history}</p>
    </section>

    {(series as any).howToWatch && (
      <section class="series-section" id="htw-section">
        <h3 class="series-section-title">How to Watch</h3>
        <div
          id="htw-root"
          data-htw={JSON.stringify((series as any).howToWatch)}
          aria-live="polite"
        ></div>
        <p class="htw-disclaimer">Broadcast rights vary by region. Check local listings.</p>
      </section>
    )}

    {series.tier === 1 && series.teamsHeaders && (
      <section class="series-section">
        <h3 class="series-section-title">Teams &amp; Drivers — 2026</h3>
        {series.seasonNotes && <p class="series-season-notes">{series.seasonNotes}</p>}
        <div class="series-table-wrap">
          <table class="series-table">
            <thead>
              <tr>
                {(series.teamsHeaders as string[]).map((h: string) => <th>{h}</th>)}
              </tr>
            </thead>
            <tbody>
              {(series.teamsRows as string[][]).map((row: string[]) => (
                <tr>
                  {row.map((cell: string) => <td>{cell}</td>)}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {series.teamsNote && <p class="series-table-note">{series.teamsNote}</p>}
      </section>
    )}

    <section class="series-section">
      <h3 class="series-section-title">2026 Calendar</h3>
      {filteredMonths.length === 0 ? (
        <p class="series-no-events">No events found for this series.</p>
      ) : (
        filteredMonths.map((month: any) => (
          <>
            <div class="month-header">{month.month}</div>
            <div class="cal-grid">
              {month.weeks.map((week: any) => (
                <div class="card">
                  <div class="c-head">{week.label}</div>
                  <div class="c-body">
                    {week.events.map((ev: any) => (
                      <div class={`event ev-${ev.series}`}>
                        <div class="ev-details">
                          <span class={`tag t-${ev.series}`}>{ev.tag}</span>
                          <span class="title">{ev.title}</span>
                          <span class="meta-time"><Fragment set:html={ev.time} /></span>
                        </div>
                        {ev.track && (
                          <div class="track-map">
                            <img
                              src={`${base}/assets/track-maps/${ev.track}`}
                              alt={`${ev.title} Track Layout Illustration`}
                              loading="lazy"
                              width="60"
                              height="60"
                            />
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </>
        ))
      )}
    </section>

    <section class="series-section">
      <h3 class="series-section-title">Subscribe &amp; Embed</h3>
      <div class="subscribe-actions">
        <a
          href={`webcal://dord.racing/ical/${slug}.ics`}
          class="subscribe-btn subscribe-btn--ical"
          aria-label={`Subscribe to ${series.name} calendar`}
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Subscribe (iCal)
        </a>
        <a
          href={`https://calendar.google.com/calendar/render?cid=webcal://dord.racing/ical/${slug}.ics`}
          target="_blank"
          rel="noopener noreferrer"
          class="subscribe-btn subscribe-btn--gcal"
          aria-label={`Add ${series.name} to Google Calendar`}
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          + Google Calendar
        </a>
        <button
          class="subscribe-btn subscribe-btn--embed"
          id="embed-btn"
          aria-haspopup="dialog"
          data-slug={slug}
          data-name={series.name}
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          Embed
        </button>
      </div>
    </section>

    <!-- Embed modal -->
    <div id="embed-modal" class="embed-modal" role="dialog" aria-modal="true" aria-labelledby="embed-modal-title" hidden>
      <div class="embed-modal-backdrop"></div>
      <div class="embed-modal-box">
        <div class="embed-modal-header">
          <h4 class="embed-modal-title" id="embed-modal-title">Embed the calendar</h4>
          <button class="embed-modal-close" aria-label="Close embed modal">&times;</button>
        </div>
        <p class="embed-modal-desc">Copy this snippet to embed a live race calendar on any website.</p>
        <pre id="embed-code" class="embed-code-block"></pre>
        <div class="embed-modal-actions">
          <button class="embed-copy-btn" id="embed-copy-btn">Copy code</button>
          <span class="embed-checks">✓ Auto-updates &nbsp; ✓ Free &nbsp; ✓ Links to dord.racing</span>
        </div>
      </div>
    </div>

    <a href={`${base}/`} class="back-link back-link--bottom">← Full Master Calendar</a>

    <Footer />
  </main>
</BaseLayout>

<script>
// ── How to Watch ───────────────────────────────────────────────
(function () {
  const root = document.getElementById('htw-root');
  if (!root) return;

  const raw = root.getAttribute('data-htw');
  if (!raw) return;

  let data: Record<string, { name: string; type: string; url: string; note?: string }[]>;
  try { data = JSON.parse(raw); } catch { return; }

  const locale = (Intl.DateTimeFormat().resolvedOptions() as any).locale
    || navigator.language || 'en-US';
  const parts = locale.split('-');
  const country = parts.length > 1 ? parts[parts.length - 1].toUpperCase() : parts[0].toUpperCase();

  const broadcasters = data[country] || data['global'];
  if (!broadcasters || broadcasters.length === 0) {
    const section = document.getElementById('htw-section');
    if (section) section.hidden = true;
    return;
  }

  const label = data[country]
    ? `Watch in <span class="htw-country">${country}</span>`
    : 'Watch globally';

  const pills = broadcasters.map(b => {
    const badgeHtml = b.type === 'free'
      ? '<span class="htw-badge htw-badge--free">FREE</span>'
      : b.type === 'streaming'
      ? '<span class="htw-badge htw-badge--stream">STREAM</span>'
      : '';
    const noteHtml = b.note ? `<span class="htw-note">${b.note}</span>` : '';
    return `<a href="${b.url}" target="_blank" rel="noopener noreferrer" class="htw-pill">${b.name}${badgeHtml}${noteHtml}</a>`;
  }).join('');

  root.innerHTML = `<p class="htw-label">${label}</p><div class="htw-pills">${pills}</div>`;
})();

// ── Embed Modal ────────────────────────────────────────────────
(function () {
  const btn = document.getElementById('embed-btn') as HTMLButtonElement | null;
  const modal = document.getElementById('embed-modal') as HTMLElement | null;
  const closeBtn = modal?.querySelector('.embed-modal-close') as HTMLButtonElement | null;
  const backdrop = modal?.querySelector('.embed-modal-backdrop') as HTMLElement | null;
  const codeEl = document.getElementById('embed-code') as HTMLElement | null;
  const copyBtn = document.getElementById('embed-copy-btn') as HTMLButtonElement | null;

  if (!btn || !modal || !codeEl) return;

  const slug = btn.dataset.slug || '';
  const name = btn.dataset.name || 'Racing';
  const iframeCode = `<iframe\n  src="https://dord.racing/embed/${slug}"\n  width="100%"\n  height="400"\n  frameborder="0"\n  style="border-radius:8px;"\n  title="${name} Race Calendar — DORD Racing"\n></iframe>\n<p style="font-size:11px;text-align:right">\n  <a href="https://dord.racing" target="_blank" rel="noopener">Full calendar at dord.racing ↗</a>\n</p>`;
  codeEl.textContent = iframeCode;

  function openModal() {
    modal!.hidden = false;
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }
  function closeModal() {
    modal!.hidden = true;
    document.body.style.overflow = '';
    btn!.focus();
  }

  btn.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);
  modal?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') closeModal();
  });

  copyBtn?.addEventListener('click', () => {
    navigator.clipboard.writeText(iframeCode).then(() => {
      copyBtn.textContent = 'Copied!';
      setTimeout(() => { copyBtn.textContent = 'Copy code'; }, 2000);
    });
  });
})();
</script>
