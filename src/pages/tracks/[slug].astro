---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';

// Vite reads these at bundle time — no node:fs needed, works in Cloudflare Workers prerender
const _svgRaw = import.meta.glob('/public/assets/track-maps/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;
const svgByFilename: Record<string, string> = {};
for (const [k, v] of Object.entries(_svgRaw)) {
  svgByFilename[k.split('/').pop()!] = v;
}
function readSvg(filename: string | undefined | null): string | null {
  if (!filename) return null;
  return svgByFilename[filename] ?? null;
}

const LAYOUT_DISPLAY: Record<string, string> = {
  motogp: 'MotoGP', f1: 'F1', fe: 'FE', wsbk: 'WSBK', nascar: 'NASCAR',
  gp: 'GP', national: 'National', indy: 'Indy', oval: 'Oval', road: 'Road',
  full: 'Full', international: 'International', foster: 'Foster', island: 'Island',
};
const layoutLabel = (id: string) => LAYOUT_DISPLAY[id] ?? id.toUpperCase();

import tracksRaw from '../../../data/tracks.json';
import calendarData from '../../../data/calendar.json';
import seriesContentData from '../../../data/seriesContent.json';

type Layout = { id: string; label: string; calendarSvgs: string[] };
type Venue = {
  slug: string;
  name: string;
  city: string;
  country: string;
  continent: string;
  browserSvg: string;
  calendarSvgs: string[];
  layouts?: Layout[];
  bio?: string;
};

export function getStaticPaths() {
  return (tracksRaw as Venue[]).map(v => ({ params: { slug: v.slug } }));
}

const { slug } = Astro.params;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const venue = (tracksRaw as Venue[]).find(v => v.slug === slug)!;

// ── Gather events from calendar ───────────────────────────────────────────────
type ResultEntry = { race_label: string; winner: string; team: string; country: string; };
type CalEvent = {
  series: string; tag: string; title: string;
  week: string; layoutId: string | null;
};
type CalResult = CalEvent & { entries: ResultEntry[]; };

const pastResults: CalResult[] = [];
const upcomingEvents: CalEvent[] = [];

for (const month of calendarData as any[]) {
  for (const week of month.weeks) {
    for (const ev of week.events) {
      if (!ev.track || !venue.calendarSvgs.includes(ev.track)) continue;
      let layoutId: string | null = null;
      if (venue.layouts) {
        const match = venue.layouts.find((l: Layout) => l.calendarSvgs.includes(ev.track));
        layoutId = match ? match.id : null;
      }
      if (ev.results?.length) {
        const isDupe = pastResults.some(e => e.series === ev.series && e.title === ev.title);
        if (!isDupe) pastResults.push({ series: ev.series, tag: ev.tag, title: ev.title, week: week.label, layoutId, entries: ev.results });
      } else {
        const isDupe = upcomingEvents.some(e => e.series === ev.series && e.title === ev.title && e.week === week.label);
        if (!isDupe) upcomingEvents.push({ series: ev.series, tag: ev.tag, title: ev.title, week: week.label, layoutId });
      }
    }
  }
}

const allEvents = [...pastResults, ...upcomingEvents];
const activeSeries = [...new Set(allEvents.map(e => e.series))];

function countryFlag(code: string): string {
  if (!code || code.length !== 2) return '';
  return [...code.toUpperCase()].map(c => String.fromCodePoint(0x1F1E6 + c.charCodeAt(0) - 65)).join('');
}

// ── SVG ───────────────────────────────────────────────────────────────────────
function cleanSvg(raw: string): string {
  return raw
    .replace(/<defs>[\s\S]*?<\/defs>/g, '')
    .replace(/<rect[^>]*fill-opacity[^>]*\/?>/g, '')
    .replace(/(\s)width="\d+"/, '')
    .replace(/(\s)height="\d+"/, '');
}

const rawSvg = readSvg(venue.browserSvg);
const hasSvg  = rawSvg !== null;
const svgContent = rawSvg ? cleanSvg(rawSvg) : null;

// For multi-layout tracks: inline each layout's SVG so we can panel-swap on hover
type LayoutWithSvg = Layout & { svgContent: string | null; };
const layoutSvgPanels: LayoutWithSvg[] = (venue.layouts ?? []).map(l => {
  const raw = readSvg(l.calendarSvgs[0]);
  return { ...l, svgContent: raw ? cleanSvg(raw) : null };
});
const hasLayoutPanels = layoutSvgPanels.length > 1 && layoutSvgPanels.some(l => l.svgContent);

function shortDate(label: string): string {
  const m = label.match(/•\s*([A-Z]{3})\s+(\d{1,2})/);
  return m ? `${m[1]} ${m[2]}` : label.replace('•', '').trim();
}

const continentLabel: Record<string, string> = {
  'europe': 'Europe', 'north-america': 'North America', 'asia': 'Asia',
  'middle-east': 'Middle East', 'south-america': 'South America', 'oceania': 'Oceania',
};

// ── SEO / structured data ─────────────────────────────────────────────────────
const seriesNameMap: Record<string, string> = Object.fromEntries(
  (seriesContentData as any[]).map((s: any) => [s.slug, s.name])
);

function parseWeekDate(label: string): string | null {
  // Parses "WEEK 04 • JAN 22-25" or "WEEK 02 • JAN 10" → ISO date (race/end day)
  const m = label.match(/([A-Z]{3})\s+(\d+)(?:-(\d+))?/);
  if (!m) return null;
  const monthMap: Record<string, number> = {
    JAN:1,FEB:2,MAR:3,APR:4,MAY:5,JUN:6,JUL:7,AUG:8,SEP:9,OCT:10,NOV:11,DEC:12,
  };
  const month = monthMap[m[1]];
  if (!month) return null;
  const day = parseInt(m[3] ?? m[2], 10); // use end/race day for multi-day spans
  return `2026-${String(month).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
}

const champCount = activeSeries.length;
const pageTitle = `${venue.name} — 2026 Motorsport Race Schedule | DORD`;
const pageDescription = champCount > 0
  ? `All 2026 races at ${venue.name} — dates, series, and session times across ${champCount} championship${champCount !== 1 ? 's' : ''}. Updated weekly.`
  : `${venue.name} circuit guide — track map, specifications, and lap record. ${venue.city}, ${venue.country}.`;

const sportsEventSchemas = [
  ...pastResults.map((ev: any) => ({ ...ev, isoDate: ev.entries[0]?.date ?? parseWeekDate(ev.week) })),
  ...upcomingEvents.map((ev: any) => ({ ...ev, isoDate: parseWeekDate(ev.week) })),
]
  .filter((ev: any) => ev.isoDate)
  .map((ev: any) => {
    const seriesName = seriesNameMap[ev.series] ?? ev.series;
    return {
      "@context": "https://schema.org",
      "@type": "SportsEvent",
      "name": `${seriesName} — ${ev.title} 2026`,
      "startDate": ev.isoDate,
      "endDate": ev.isoDate,
      "url": `https://dord.racing/tracks/${slug}`,
      "sport": "Motorsport",
      "eventStatus": "https://schema.org/EventScheduled",
      "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
      "description": `2026 ${seriesName} event — ${ev.title} at ${venue.name}, ${venue.city}.`,
      "image": "https://dord.racing/assets/og/og-tracks.webp",
      "organizer": {
        "@type": "SportsOrganization",
        "name": seriesName,
      },
      "performer": {
        "@type": "SportsOrganization",
        "name": seriesName,
      },
      "offers": {
        "@type": "Offer",
        "url": `https://dord.racing/tracks/${slug}`,
        "availability": "https://schema.org/InStock",
        "price": "0",
        "priceCurrency": "EUR",
        "validFrom": "2026-01-01",
      },
      "location": {
        "@type": "Place",
        "name": venue.name,
        "address": {
          "@type": "PostalAddress",
          "addressLocality": venue.city,
          "addressCountry": venue.country,
        },
        ...((venue as any).website ? { "url": (venue as any).website } : {}),
      },
    };
  });
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={`https://dord.racing/tracks/${slug}`}
  ogImage="https://dord.racing/assets/og/og-tracks.webp"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SportsActivityLocation",
      "name": venue.name,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": venue.city,
        "addressCountry": venue.country,
      },
      "url": `https://dord.racing/tracks/${slug}`,
      ...((venue as any).website ? { "sameAs": (venue as any).website } : {}),
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dord.racing" },
        { "@type": "ListItem", "position": 2, "name": "Track Browser", "item": "https://dord.racing/tracks" },
        { "@type": "ListItem", "position": 3, "name": venue.name, "item": `https://dord.racing/tracks/${slug}` },
      ],
    })} />
    {sportsEventSchemas.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(sportsEventSchemas)} />
    )}
  </Fragment>
  <header>
    <div class="header--left">
      <div class="header--dept">The Department of Racing Drivers</div>
      <h1>{venue.name} — 2026 Race Calendar</h1>
      <div class="meta">{venue.city} · {venue.country} · {continentLabel[venue.continent] ?? venue.continent}</div>
      <Nav activePage="tracks" />
    </div>
  </header>

  <main id="main-content" class="track-page">

    <a href={`${base}/tracks`} class="back-link">← All Circuits</a>

    <!-- Hero -->
    <div class="track-hero" style={`background-image: url('${base}/assets/track-bgs/${'bg' in venue && (venue as any).bg ? (venue as any).bg : 'default.jpg'}')`}>
      <div class="track-hero-svg">
        {hasLayoutPanels ? (
          layoutSvgPanels.map((l, i) => (
            <div class="layout-panel" data-layout-id={l.id} style={i === 0 ? '' : 'display:none'}>
              {l.svgContent
                ? <Fragment set:html={l.svgContent} />
                : <div class="hero-placeholder">{l.label}</div>
              }
            </div>
          ))
        ) : (
          svgContent
            ? <Fragment set:html={svgContent} />
            : <div class="hero-placeholder">{venue.name}</div>
        )}
      </div>
      {hasLayoutPanels && (
        <div class="layout-btns">
          {layoutSvgPanels.map((l, i) => (
            <button
              class={`layout-btn${i === 0 ? ' active' : ''}`}
              data-layout-target={l.id}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              {layoutLabel(l.id)}
            </button>
          ))}
        </div>
      )}
    </div>

    <!-- Name + Info -->
    <div class="track-meta-row">
      <div class="track-meta-left">
        <h2 class="track-name">{venue.name}</h2>
        <div class="track-location">{venue.city} · {venue.country}</div>
        {activeSeries.length > 0 && (
          <div class="track-series-list">
            {activeSeries.map(s => (
              <a href={`${base}/series/${s}`} class={`tag t-${s}`}>
                {allEvents.find(e => e.series === s)?.tag}
              </a>
            ))}
          </div>
        )}
      </div>
      {venue.bio && (
        <p class="track-bio">{venue.bio}</p>
      )}
    </div>

    <!-- Circuit specs -->
    {((venue as any).length || (venue as any).turns || (venue as any).type || (venue as any).lapRecord || (venue as any).website) && (
      <div class="track-specs-row">
        {(venue as any).length && (
          <div class="spec-item">
            <div class="spec-label">Length</div>
            <div class="spec-value">{(venue as any).length} km</div>
          </div>
        )}
        {(venue as any).turns && (
          <div class="spec-item">
            <div class="spec-label">Turns</div>
            <div class="spec-value">{(venue as any).turns}</div>
          </div>
        )}
        {(venue as any).direction && (
          <div class="spec-item">
            <div class="spec-label">Direction</div>
            <div class="spec-value">{(venue as any).direction}</div>
          </div>
        )}
        {(venue as any).type && (
          <div class="spec-item">
            <div class="spec-label">Type</div>
            <div class="spec-value">{(venue as any).type}</div>
          </div>
        )}
        {(venue as any).lapRecord && (
          <div class="spec-item spec-item--lap">
            <div class="spec-label">Lap Record</div>
            <div class="spec-value">{(venue as any).lapRecord.time}</div>
            <div class="spec-sub">{(venue as any).lapRecord.driver} · {(venue as any).lapRecord.series} · {(venue as any).lapRecord.year}</div>
          </div>
        )}
        {(venue as any).website && (
          <div class="spec-item spec-item--link">
            <a href={(venue as any).website} target="_blank" rel="noopener noreferrer" class="spec-website">
              <img src={`${base}/assets/website-icon.svg`} alt="" width="14" height="14" />
              Official Site
            </a>
          </div>
        )}
      </div>
    )}

    <!-- Layouts -->
    {venue.layouts && (
      <div class="track-layouts-section">
        <div class="section-label">LAYOUTS IN USE</div>
        <div class="layouts-list">
          {venue.layouts.map(l => (
            <div class="layout-row">
              <span class="layout-id">{layoutLabel(l.id)}</span>
              <span class="layout-label">{l.label}</span>
              <div class="layout-series">
                {allEvents
                  .filter(e => e.layoutId === l.id)
                  .map(e => (
                    <a href={`${base}/series/${e.series}`} class={`tag t-${e.series}`}>{e.tag}</a>
                  ))
                }
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Results -->
    {pastResults.length > 0 && (
      <div class="track-events-section">
        <div class="section-label">RESULTS</div>
        <div class="results-list">
          {pastResults.map(ev => (
            <div class="result-block" data-layout-id={ev.layoutId ?? undefined}>
              <div class="result-header">
                <span class="ev-date">{shortDate(ev.week)}</span>
                <a href={`${base}/series/${ev.series}`} class={`tag t-${ev.series}`}>{ev.tag}</a>
                <span class="ev-title">{ev.title}</span>
              </div>
              <div class="result-entries">
                {ev.entries.map((r: ResultEntry) => (
                  <div class="result-entry">
                    <span class="res-label">{r.race_label}</span>
                    <span class="res-winner">{r.winner}</span>
                    <span class="res-team">{r.team}</span>
                    <span class="res-flag">{countryFlag(r.country)}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Upcoming events -->
    {(upcomingEvents.length > 0 || pastResults.length === 0) && (
      <div class="track-events-section">
        <div class="section-label">{pastResults.length > 0 ? 'UPCOMING' : '2026 EVENTS'}</div>
        {upcomingEvents.length > 0 ? (
          <div class="events-list">
            {upcomingEvents.map(ev => (
              <div class="ev-row" data-layout-id={ev.layoutId ?? undefined}>
                <span class="ev-date">{shortDate(ev.week)}</span>
                <a href={`${base}/series/${ev.series}`} class={`tag t-${ev.series}`}>{ev.tag}</a>
                <span class="ev-title">{ev.title}</span>
              </div>
            ))}
          </div>
        ) : (
          <p class="no-events">No events at this venue in 2026.</p>
        )}
      </div>
    )}

    <a href={`${base}/tracks`} class="back-link back-link--bottom">← All Circuits</a>

  </main>
</BaseLayout>

<script>
  // Layout button switching
  const panels = document.querySelectorAll<HTMLElement>('.layout-panel');
  const btns   = document.querySelectorAll<HTMLButtonElement>('.layout-btn');

  if (panels.length > 1 && btns.length > 0) {
    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.layoutTarget!;
        panels.forEach(p => { p.style.display = p.dataset.layoutId === target ? '' : 'none'; });
        btns.forEach(b => {
          b.classList.toggle('active', b.dataset.layoutTarget === target);
          b.setAttribute('aria-pressed', b.dataset.layoutTarget === target ? 'true' : 'false');
        });
      });
    });
  }
</script>

<style>
  .track-page {
    padding: 0 24px 80px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    font-family: 'Roboto Mono', monospace;
    font-size: 0.72rem;
    color: #556;
    text-decoration: none;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 24px;
    transition: color 0.15s;
  }
  .back-link:hover { color: #aaa; }
  .back-link--bottom { margin-top: 48px; margin-bottom: 0; }

  /* ── Hero ────────────────────────────────────────────────────────────────── */
  .track-hero {
    position: relative;
    background: var(--bg);
    background-size: cover;
    background-position: center;
    border: 1px solid var(--border);
    aspect-ratio: 3 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0;
  }

  .track-hero-svg {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .track-hero-svg :global(svg) {
    width: 100%;
    height: 100%;
    max-height: 320px;
  }

  .track-hero-svg :global(.layout-panel) {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.18s ease;
  }

  .track-hero-svg :global(svg path) {
    stroke-width: 1 !important;
  }

  .hero-placeholder {
    font-family: 'Roboto Mono', monospace;
    font-size: 0.8rem;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.4;
  }

  .layout-btns {
    position: absolute;
    bottom: 12px;
    right: 12px;
    display: flex;
    gap: 4px;
    z-index: 2;
  }

  .layout-btn {
    font-family: 'Roboto Mono', monospace;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #445;
    background: rgba(0, 0, 0, 0.55);
    border: 1px solid #334;
    border-radius: 3px;
    padding: 4px 8px;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  .layout-btn:hover {
    color: #778;
    border-color: #556;
  }

  .layout-btn.active {
    color: #c3c6c8;
    border-color: #667;
  }

  /* ── Meta row ────────────────────────────────────────────────────────────── */
  .track-meta-row {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 32px;
    border: 1px solid var(--border);
    border-top: none;
    padding: 24px;
    background: var(--card-bg);
    margin-bottom: 2px;
  }

  @media (max-width: 680px) {
    .track-meta-row { grid-template-columns: 1fr; }
  }

  /* ── Circuit specs bar ───────────────────────────────────────────────────── */
  .track-specs-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    border: 1px solid var(--border);
    border-top: none;
    background: var(--card-bg);
    margin-bottom: 2px;
  }

  .spec-item {
    padding: 14px 20px;
    border-right: 1px solid var(--border);
    min-width: 100px;
  }

  .spec-item:last-child {
    border-right: none;
  }

  .spec-item--lap {
    flex: 1;
  }

  .spec-item--link {
    display: flex;
    align-items: center;
    margin-left: auto;
    border-right: none;
    border-left: 1px solid var(--border);
  }

  .spec-label {
    font-family: 'Roboto Mono', monospace;
    font-size: 0.55rem;
    color: #445;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 5px;
  }

  .spec-value {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: #c3c6c8;
    letter-spacing: 0.03em;
  }

  .spec-sub {
    font-family: 'Roboto Mono', monospace;
    font-size: 0.6rem;
    color: #556;
    margin-top: 3px;
    letter-spacing: 0.03em;
  }

  .spec-website {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: 'Roboto Mono', monospace;
    font-size: 0.65rem;
    color: #556;
    text-decoration: none;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: color 0.15s;
    white-space: nowrap;
  }

  .spec-website:hover { color: #aaa; }

  .spec-website img { opacity: 0.5; }

  @media (max-width: 560px) {
    .track-specs-row { flex-direction: column; }
    .spec-item { border-right: none; border-bottom: 1px solid var(--border); }
    .spec-item--link { border-left: none; border-bottom: none; margin-left: 0; }
  }

  .track-name {
    font-size: 1.05rem;
    font-weight: 800;
    color: #c3c6c8;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 4px;
    line-height: 1.2;
  }

  .track-location {
    font-family: 'Roboto Mono', monospace;
    font-size: 0.68rem;
    color: #556;
    letter-spacing: 0.05em;
    margin-bottom: 14px;
  }

  .track-series-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .track-series-list .tag {
    font-size: 0.62rem;
    text-decoration: none;
    padding: 3px 7px;
  }

  .track-bio {
    font-size: 0.82rem;
    color: #8a9499;
    line-height: 1.65;
    margin: 0;
    padding-top: 2px;
  }

  /* ── Layouts ─────────────────────────────────────────────────────────────── */
  .track-layouts-section,
  .track-events-section {
    border: 1px solid var(--border);
    border-top: none;
    background: var(--card-bg);
    padding: 20px 24px;
    margin-bottom: 2px;
  }

  .section-label {
    font-family: 'Roboto Mono', monospace;
    font-size: 0.6rem;
    color: #445;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .layouts-list { display: flex; flex-direction: column; gap: 10px; }

  .layout-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .layout-id {
    font-family: 'Roboto Mono', monospace;
    font-size: 0.6rem;
    color: #445;
    letter-spacing: 0.08em;
    min-width: 36px;
  }

  .layout-label {
    font-size: 0.78rem;
    color: #7a8890;
    flex: 1;
