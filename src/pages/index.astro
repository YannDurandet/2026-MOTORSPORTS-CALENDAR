---
import BaseLayout from '../layouts/BaseLayout.astro';
import Banner from '../components/Banner.astro';
import Nav from '../components/Nav.astro';
import Dashboard from '../components/Dashboard.astro';
import EventRow from '../components/EventRow.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

// Import data at build time
import calendarData from '../../data/calendar.json';

---
<BaseLayout
  title="2026 MOTORSPORT MASTER CALENDAR"
  description="The ultimate 2026 motorsport master calendar. Track F1, WEC, IMSA, MotoGP, IndyCar, and more with live countdowns and local track times."
  canonicalUrl="https://yanndurandet.me/racing"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What time zone are the race times in?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "All times are displayed in your system time. By default, the master calendar is built using Paris (CET/CEST) timezone."
          }
        },
        {
          "@type": "Question",
          "name": "When does the 2026 Formula 1 season start?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The 2026 F1 season kicks off with the Australian Grand Prix on March 8, 2026."
          }
        },
        {
          "@type": "Question",
          "name": "Which series are included in this tracker?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We track 21 major global and regional championships including Formula 1, WEC, IMSA, IndyCar, WRC, MotoGP, WorldSBK, NASCAR, and Supercars."
          }
        }
      ]
    })} />
  </Fragment>

  <Banner />
  <header>
    <div class="header--left">
      <h1>THE DEPARTMENT OF RACING DRIVERS<br>2026 MOTORSPORT MASTER CALENDAR</h1>
      <div class="meta">SYSTEM TIMEZONE: PARIS (CET/CEST)</div>
      <div class="website-description">The ultimate 2026 motorsport master calendar. Track every race weekend
        across global and regional series, including Formula 1, WEC, IMSA, IndyCar, MotoGP, and WRC.<br> Use
        the filters to customize your schedule by open-wheel, endurance, or touring cars. All countdowns and
        schedules are localized to Paris CET/CEST time.</div>
      <Nav activePage="calendar" />
    </div>
    <Dashboard />
  </header>

  <div class="main-section">
    <div id="this-weekend" class="this-weekend-section" hidden>
      <div class="this-weekend-header">THIS WEEKEND</div>
      <div id="this-weekend-grid" class="this-weekend-grid"></div>
    </div>

    <div id="filter-bar" class="filter-bar">
      <fieldset class="filter-group" id="region-filters">
        <legend>Region</legend>
      </fieldset>
      <fieldset class="filter-group" id="category-filters">
        <legend>Category</legend>
      </fieldset>
      <details class="advanced-filters" id="advanced-filters">
        <summary>Advanced: Toggle Specific Series</summary>
        <div class="advanced-series-grid" id="series-toggles"></div>
      </details>
    </div>

    <div id="empty-state" class="empty-state" hidden>
      <p>No events match your current filters.</p>
      <button id="clear-filters-btn" class="clear-filters-btn">Clear Filters</button>
    </div>

    <details id="past-events-container" class="past-events-accordion">
      <summary id="past-events-summary" aria-expanded="false">View Past Events</summary>
    </details>

    <div id="calendar-container">
      {(calendarData as any[]).map((month: any) => (
        <>
          <div class="month-header">{month.month}</div>
          <div class="cal-grid">
            {month.weeks.map((week: any) => (
              <div class="card">
                <div class="c-head">{week.label}</div>
                <div class="c-body">
                  {week.events.map((ev: any) => (
                    <EventRow
                      series={ev.series}
                      tag={ev.tag}
                      title={ev.title}
                      time={ev.time}
                      track={ev.track}
                      sprint={ev.sprint}
                      sub={ev.sub}
                      races={ev.races}
                      weekLabel={week.label}
                    />
                  ))}
                </div>
              </div>
            ))}
          </div>
        </>
      ))}
    </div>

    <FAQ />
    <Footer />
  </div>

  <script src="../scripts/main.js"></script>
</BaseLayout>
