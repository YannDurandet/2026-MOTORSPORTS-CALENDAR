---
import BaseLayout from '../layouts/BaseLayout.astro';
import Banner from '../components/Banner.astro';
import Nav from '../components/Nav.astro';
import Dashboard from '../components/Dashboard.astro';
import NewsCard from '../components/NewsCard.astro';
import EventRow from '../components/EventRow.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

// Import data at build time
import calendarData from '../../data/calendar.json';
import resultsData from '../../data/results.json';
import seriesData from '../../data/series.json';
import newsData from '../../data/news.json';

// Build results lookup: "series|EVENT" → array of result objects
const resultsLookup: Record<string, any[]> = {};
for (const [series, races] of Object.entries(resultsData as Record<string, any[]>)) {
  for (const r of races) {
    const key = `${series}|${r.event}`;
    if (!resultsLookup[key]) resultsLookup[key] = [];
    resultsLookup[key].push(r);
  }
}

const MONTH_MAP: Record<string, number> = {
  JAN: 0, FEB: 1, MAR: 2, APR: 3, MAY: 4, JUN: 5,
  JUL: 6, AUG: 7, SEP: 8, OCT: 9, NOV: 10, DEC: 11
};

function parseWeekDate(weekLabel: string): Date | null {
  const m = weekLabel.match(/\u2022\s*([A-Z]{3})\s+(\d{1,2})(?:\s*-\s*(\d{1,2}))?/);
  if (!m) return null;
  const mo = MONTH_MAP[m[1]];
  if (mo === undefined) return null;
  const day = m[3] ? parseInt(m[3]) : parseInt(m[2]);
  return new Date(2026, mo, day);
}

function findSeriesDate(seriesKey: string, weekLabel: string) {
  const list = (seriesData as Record<string, any[]>)[seriesKey];
  if (!list) return null;
  const refDate = parseWeekDate(weekLabel);
  if (!refDate) return null;
  const m = weekLabel.match(/\u2022\s*([A-Z]{3})\s+(\d{1,2})/);
  if (!m) return null;
  const startDay = parseInt(m[2]);
  const weekStart = new Date(2026, MONTH_MAP[m[1]], startDay);
  const weekEnd = new Date(refDate.getTime() + 86400000);
  return list.find((r: any) => {
    const d = new Date(r.date);
    return d >= weekStart && d <= weekEnd;
  }) || null;
}

function shortenDriver(name: string): string {
  if (!name) return '';
  const drivers = name.split('/').map((d: string) => d.trim());
  const first = drivers[0].split(' ');
  const short = first.length > 1 ? first[0][0] + '. ' + first.slice(1).join(' ') : first[0];
  return drivers.length > 1 ? short + ' +' + (drivers.length - 1) : short;
}

function renderResultBadge(seriesKey: string, weekLabel: string): string {
  const match = findSeriesDate(seriesKey, weekLabel);
  if (!match) return '';
  const results = resultsLookup[`${seriesKey}|${match.name}`];
  if (!results || !results.length) return '';
  let html = '';
  for (const r of results) {
    if (r.driver === null) {
      html += `<div class="result-line result-cancelled">Cancelled</div>`;
    } else {
      const note = r.note ? ` <span class="result-note">(${r.note})</span>` : '';
      html += `<div class="result-line"><span class="result-icon">\u2605</span><span class="result-driver">${shortenDriver(r.driver)}</span><span class="result-team">${r.team}${note}</span></div>`;
    }
  }
  return html;
}

// Only show first 4 news items on index page
const indexNews = (newsData as any[]).slice(0, 4);
---
<BaseLayout
  title="2026 MOTORSPORT MASTER CALENDAR"
  description="The ultimate 2026 motorsport master calendar. Track F1, WEC, IMSA, MotoGP, IndyCar, and more with live countdowns and local track times."
  canonicalUrl="https://yanndurandet.me/racing"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What time zone are the race times in?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "All times are displayed in your system time. By default, the master calendar is built using Paris (CET/CEST) timezone."
          }
        },
        {
          "@type": "Question",
          "name": "When does the 2026 Formula 1 season start?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The 2026 F1 season kicks off with the Australian Grand Prix on March 8, 2026."
          }
        },
        {
          "@type": "Question",
          "name": "Which series are included in this tracker?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We track 21 major global and regional championships including Formula 1, WEC, IMSA, IndyCar, WRC, MotoGP, WorldSBK, NASCAR, and Supercars."
          }
        }
      ]
    })} />
  </Fragment>

  <Banner />
  <header>
    <div class="header--left">
      <h1>THE DEPARTMENT OF RACING DRIVERS<br>2026 MOTORSPORT MASTER CALENDAR</h1>
      <div class="meta">SYSTEM TIMEZONE: PARIS (CET/CEST)</div>
      <div class="website-description">The ultimate 2026 motorsport master calendar. Track every race weekend
        across global and regional series, including Formula 1, WEC, IMSA, IndyCar, MotoGP, and WRC.<br> Use
        the filters to customize your schedule by open-wheel, endurance, or touring cars. All countdowns and
        schedules are localized to Paris CET/CEST time.</div>
      <Nav activePage="calendar" />
    </div>
    <Dashboard />
  </header>

  <div class="news-section">
    <div class="news-header-title">LATEST NEWS</div>
    <div class="news-grid">
      {indexNews.map((news: any) => (
        <NewsCard {...news} />
      ))}
    </div>
    <div class="news-more-wrapper">
      <a href={`${import.meta.env.BASE_URL}/news`} class="news-more-btn">MORE NEWS &gt;</a>
    </div>

    <div id="this-weekend" class="this-weekend-section" hidden>
      <div class="this-weekend-header">THIS WEEKEND</div>
      <div id="this-weekend-grid" class="this-weekend-grid"></div>
    </div>

    <div id="filter-bar" class="filter-bar">
      <fieldset class="filter-group" id="region-filters">
        <legend>Region</legend>
      </fieldset>
      <fieldset class="filter-group" id="category-filters">
        <legend>Category</legend>
      </fieldset>
      <details class="advanced-filters" id="advanced-filters">
        <summary>Advanced: Toggle Specific Series</summary>
        <div class="advanced-series-grid" id="series-toggles"></div>
      </details>
    </div>

    <div id="empty-state" class="empty-state" hidden>
      <p>No events match your current filters.</p>
      <button id="clear-filters-btn" class="clear-filters-btn">Clear Filters</button>
    </div>

    <details id="past-events-container" class="past-events-accordion">
      <summary id="past-events-summary" aria-expanded="false">View Past Events</summary>
    </details>

    <div id="calendar-container">
      {(calendarData as any[]).map((month: any) => (
        <>
          <div class="month-header">{month.month}</div>
          <div class="cal-grid">
            {month.weeks.map((week: any) => (
              <div class="card">
                <div class="c-head">{week.label}</div>
                <div class="c-body">
                  {week.events.map((ev: any) => (
                    <EventRow
                      series={ev.series}
                      tag={ev.tag}
                      title={ev.title}
                      time={ev.time}
                      track={ev.track}
                      sprint={ev.sprint}
                      sub={ev.sub}
                      weekLabel={week.label}
                      resultHtml={renderResultBadge(ev.series, week.label)}
                    />
                  ))}
                </div>
              </div>
            ))}
          </div>
        </>
      ))}
    </div>

    <FAQ />
    <Footer />
  </div>

  <script src="../scripts/main.js"></script>
</BaseLayout>
