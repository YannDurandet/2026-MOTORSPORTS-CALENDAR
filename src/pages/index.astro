---
import BaseLayout from '../layouts/BaseLayout.astro';
import Banner from '../components/Banner.astro';
import Nav from '../components/Nav.astro';
import EventRow from '../components/EventRow.astro';
import NewsletterBanner from '../components/NewsletterBanner.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

// Import data at build time
import calendarData from '../../data/calendar.json';
import tracksData from '../../data/tracks.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const trackSlugs = new Set((tracksData as any[]).map((t: any) => t.slug));

// Find the calendar index of the current month so we can inject the newsletter
// banner directly after it. Position is set at build time; the site is rebuilt
// weekly for results anyway, so this stays current.
const _todayMonth = new Date().getMonth(); // 0-indexed
const _monthNames = ['january','february','march','april','may','june','july','august','september','october','november','december'];
const newsletterAfterIdx = (calendarData as any[]).findIndex((m: any) =>
  m.month.toLowerCase().includes(_monthNames[_todayMonth])
);

function stripTrackSuffix(svgName: string): string {
  return svgName.replace(/\.svg$/, '').replace(/-(f1|motogp|fe|wsbk|oval|road)$/, '');
}

const enrichedCalendar = (calendarData as any[]).map((month: any) => ({
  ...month,
  weeks: month.weeks.map((week: any) => ({
    ...week,
    events: week.events.map((ev: any) => {
      const slug = stripTrackSuffix(ev.track ?? '');
      const trackHref = trackSlugs.has(slug) ? `${base}/tracks/${slug}` : null;
      return { ...ev, trackHref };
    }),
  })),
}));

---
<BaseLayout
  title="2026 Motorsport Calendar — F1, WEC, MotoGP, IndyCar & 25 Championships"
  description="The ultimate 2026 motorsport master calendar. Track F1, WEC, IMSA, MotoGP, IndyCar, and more with live countdowns and local track times."
  canonicalUrl="https://dord.racing"
  ogImage="https://dord.racing/assets/og/og-home.webp"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "DORD Racing",
      "alternateName": "The Department of Racing Drivers",
      "url": "https://dord.racing",
      "logo": "https://dord.racing/assets/og/og-home.webp",
      "sameAs": [
        "https://x.com/dord_racing",
        "https://www.instagram.com/dord.racing/"
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "2026 Motorsport Master Calendar",
      "alternateName": "dord.racing",
      "url": "https://dord.racing",
      "description": "The ultimate 2026 motorsport master calendar tracking 25 championships across open-wheel, endurance, touring, GT, bike, and rally series.",
      "publisher": {
        "@type": "Organization",
        "name": "DORD Racing",
        "url": "https://dord.racing"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "When does the 2026 Formula 1 season start?",
          "acceptedAnswer": { "@type": "Answer", "text": "The 2026 FIA Formula One World Championship begins with the Australian Grand Prix at Melbourne's Albert Park Circuit on March 8, 2026. The season runs 22 rounds across five continents, concluding at the Abu Dhabi Grand Prix on December 6, 2026." }
        },
        {
          "@type": "Question",
          "name": "What's new in Formula 1 for 2026?",
          "acceptedAnswer": { "@type": "Answer", "text": "The 2026 season introduces the most significant technical overhaul in F1's modern era. All-new power unit regulations bring a new hybrid formula with a 50/50 split between combustion and electrical power, alongside completely redesigned aerodynamics featuring active front and rear wings. New entrants Audi and the GM/Cadillac works team join the grid. A new street circuit in Madrid, the Madring, makes its F1 debut in September." }
        },
        {
          "@type": "Question",
          "name": "Why are Bahrain and Saudi Arabia not on the 2026 F1 calendar?",
          "acceptedAnswer": { "@type": "Answer", "text": "Both the Bahrain Grand Prix and the Saudi Arabian Grand Prix are absent from the 2026 Formula One World Championship calendar. The Saudi Arabian GP was removed due to ongoing regional instability, while Bahrain did not reach a new hosting agreement in time for the 2026 schedule." }
        },
        {
          "@type": "Question",
          "name": "When is the 24 Hours of Le Mans 2026?",
          "acceptedAnswer": { "@type": "Answer", "text": "The 2026 24 Hours of Le Mans takes place June 10–14 at the Circuit de la Sarthe in Le Mans, France. It is the centrepiece of the FIA World Endurance Championship and the most prestigious endurance race in the world, contested by Hypercar and GT3 machinery." }
        },
        {
          "@type": "Question",
          "name": "When does the 2026 MotoGP season start?",
          "acceptedAnswer": { "@type": "Answer", "text": "The 2026 MotoGP World Championship begins with the Thai Grand Prix at the Chang International Circuit in Buriram on February 27–March 1. The season spans 22 rounds across five continents and marks the final year of the current 1000cc engine regulations before major technical changes arrive in 2027." }
        },
        {
          "@type": "Question",
          "name": "When is the 2026 Daytona 500?",
          "acceptedAnswer": { "@type": "Answer", "text": "The 2026 Daytona 500, the season-opening crown jewel of the NASCAR Cup Series, takes place on February 15, 2026 at Daytona International Speedway in Daytona Beach, Florida." }
        },
        {
          "@type": "Question",
          "name": "When does the 2026 IndyCar season start?",
          "acceptedAnswer": { "@type": "Answer", "text": "The 2026 NTT IndyCar Series season opens with the Firestone Grand Prix of St. Petersburg on March 1, 2026. The 16-race schedule includes the 110th Running of the Indianapolis 500 on May 24." }
        },
        {
          "@type": "Question",
          "name": "What is the difference between WEC and IMSA?",
          "acceptedAnswer": { "@type": "Answer", "text": "The FIA World Endurance Championship (WEC) is the global endurance series, peaking with the 24 Hours of Le Mans and racing across Europe, Asia, and the Americas. IMSA (the WeatherTech SportsCar Championship) is the premier North American endurance series, built around tracks like Daytona, Sebring, and Watkins Glen. Both share the same GTP Hypercar class and often feature identical manufacturer programmes." }
        },
        {
          "@type": "Question",
          "name": "Which series are tracked in this calendar?",
          "acceptedAnswer": { "@type": "Answer", "text": "We track 25 major global and regional championships: Formula 1, F1 Academy, Formula E, Super Formula, WEC, IMSA, WRC, ERC, IndyCar, NASCAR, MotoGP, WorldSBK, DTM, BTCC, Australian Supercars, ELMS, GT World Challenge Europe, GT World Challenge America, NLS, IGTC, TCR World, 24H European Series, Porsche Mobil 1 Supercup, British GT, and FIA European Rallycross. Indy NXT, F2, and F3 appear as support events within their parent series." }
        },
      ]
    })} />
  </Fragment>

  <Banner />
  <header>
    <div class="header--left">
      <div class="header--dept">The Department of Racing Drivers</div>
      <h1>2026 Motorsport<br>Master Calendar</h1>
      <div class="meta">SYSTEM TIMEZONE: PARIS (CET/CEST)</div>
      <div class="website-description">The ultimate 2026 motorsport master calendar. Track every race weekend
        across global and regional series, including Formula 1, WEC, IMSA, IndyCar, MotoGP, and WRC.<br> Use
        the filters to customize your schedule by open-wheel, endurance, or touring cars. All countdowns and
        schedules are localized to Paris CET/CEST time.</div>
      <Nav activePage="calendar" />
    </div>
  </header>

  <main id="main-content" class="main-section">
    <div id="this-weekend" class="this-weekend-section" hidden>
      <div class="this-weekend-header">THIS WEEKEND</div>
      <div id="this-weekend-grid" class="this-weekend-grid"></div>
    </div>

    <div id="filter-bar" class="filter-bar">
      <fieldset class="filter-group" id="region-filters">
        <legend>Region</legend>
      </fieldset>
      <fieldset class="filter-group" id="category-filters">
        <legend>Category</legend>
      </fieldset>
      <details class="advanced-filters" id="advanced-filters">
        <summary>Advanced: Toggle Specific Series</summary>
        <div class="advanced-series-grid" id="series-toggles"></div>
      </details>
      <div class="filter-active-bar" id="filter-active-bar">
        <span class="filter-active-label">Filters active</span>
        <button class="clear-all-btn" id="clear-all-filters">Clear all ×</button>
      </div>
    </div>

    <div id="empty-state" class="empty-state" hidden>
      <p>No events match your current filters.</p>
      <button id="clear-filters-btn" class="clear-filters-btn">Clear Filters</button>
    </div>

    <details id="past-events-container" class="past-events-accordion">
      <summary id="past-events-summary">View Past Events</summary>
    </details>

    <div id="calendar-container">
      {enrichedCalendar.map((month: any, idx: number) => (
        <>
          <div class="month-header">{month.month}</div>
          <div class="cal-grid">
            {month.weeks.map((week: any) => (
              <div class="card">
                <div class="c-head">{week.label}</div>
                <div class="c-body">
                  {week.events.map((ev: any) => (
                    <EventRow
                      series={ev.series}
                      tag={ev.tag}
                      title={ev.title}
                      time={ev.time}
                      track={ev.track}
                      sprint={ev.sprint}
                      sub={ev.sub}
                      races={ev.races}
                      trackHref={ev.trackHref}
                    />
                  ))}
                </div>
              </div>
            ))}
          </div>
          {idx === newsletterAfterIdx && <NewsletterBanner />}
        </>
      ))}
    </div>

    <FAQ />
    <Footer />
  </main>

  <script src="../scripts/main.js"></script>
</BaseLayout>
